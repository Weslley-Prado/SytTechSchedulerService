                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "04 - Availability",
      "item": [
        {
          "name": "GET /availability — slots dos próximos 7 dias",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const now = new Date();",
                  "const from = new Date(now.getTime() + 60*60*1000);",
                  "const to = new Date(now.getTime() + 7*24*60*60*1000);",
                  "pm.collectionVariables.set('availabilityFrom', from.toISOString());",
                  "pm.collectionVariables.set('availabilityTo', to.toISOString());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('serviceId')) { pm.test.skip('sem serviceId'); return; }",
                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "const slots = j.slots || [];",
                  "pm.test('slots é array', () => pm.expect(slots).to.be.an('array'));",
                  "if (slots.length) {",
                  "    pm.collectionVariables.set('slotStart', slots[0].start);",
                  "    pm.collectionVariables.set('slotEnd', slots[0].end);",
                  "    if (slots[0].professionalId) pm.collectionVariables.set('professionalId', slots[0].professionalId);",
                  "    console.log('slot escolhido:', slots[0]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/availability?unitId={{unitId}}&serviceId={{serviceId}}&from={{availabilityFrom}}&to={{availabilityTo}}&timezone=America/Sao_Paulo",
              "host": ["{{baseUrl}}"],
              "path": ["availability"],
              "query": [
                { "key": "unitId", "value": "{{unitId}}" },
                { "key": "serviceId", "value": "{{serviceId}}" },
                { "key": "from", "value": "{{availabilityFrom}}" },
                { "key": "to", "value": "{{availabilityTo}}" },
                { "key": "timezone", "value": "America/Sao_Paulo" }
              ]
            }
          }
        },
        {
          "name": "GET /availability — 422 sem parâmetros obrigatórios",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/availability", "host": ["{{baseUrl}}"], "path": ["availability"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('400/422', () => pm.expect(pm.response.code).to.be.oneOf([400, 422]));"]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05 - Appointment Lifecycle (Hold → Confirm → Reschedule → Cancel)",
      "item": [
        {
          "name": "POST /appointments/holds — criar pré-reserva",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitId\": \"{{unitId}}\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"professionalId\": \"{{professionalId}}\",\n  \"start\": \"{{slotStart}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/appointments/holds", "host": ["{{baseUrl}}"], "path": ["appointments", "holds"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('slotStart')) { pm.test.skip('rode availability antes'); return; }",
                  "pm.test('201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.collectionVariables.set('holdId', j.holdId);",
                  "console.log('holdId =', j.holdId);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /appointments/holds — 409 horário ocupado",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitId\": \"{{unitId}}\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"professionalId\": \"{{professionalId}}\",\n  \"start\": \"{{slotStart}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/appointments/holds", "host": ["{{baseUrl}}"], "path": ["appointments", "holds"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('409 Conflict (slot já reservado)', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /appointments — confirmar (cria appointment)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"holdId\": \"{{holdId}}\",\n  \"customer\": {\n    \"fullName\": \"Weslley Teste\",\n    \"email\": \"{{email}}\",\n    \"phone\": \"+5511999990000\",\n    \"notes\": \"primeira vez\"\n  }\n}"
            },
            "url": { "raw": "{{baseUrl}}/appointments", "host": ["{{baseUrl}}"], "path": ["appointments"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('holdId')) { pm.test.skip('sem holdId'); return; }",
                  "pm.test('201', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "pm.collectionVariables.set('appointmentId', j.appointmentId);",
                  "pm.collectionVariables.set('appointmentCode', j.code);",
                  "console.log('appointmentId =', j.appointmentId, '| code =', j.code);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /appointments — 410 hold já consumido/expirado",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"holdId\": \"{{holdId}}\",\n  \"customer\": {\n    \"fullName\": \"Weslley Teste\",\n    \"email\": \"{{email}}\",\n    \"phone\": \"+5511999990000\"\n  }\n}"
            },
            "url": { "raw": "{{baseUrl}}/appointments", "host": ["{{baseUrl}}"], "path": ["appointments"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('410 Gone ou 404', () => pm.expect(pm.response.code).to.be.oneOf([404, 410, 422]));"

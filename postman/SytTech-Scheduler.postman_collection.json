        {
          "name": "PATCH /appointments/{id}/reschedule — novo horário",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const newStart = new Date(Date.now() + 2*24*60*60*1000);",
                  "newStart.setUTCHours(13, 0, 0, 0);",
                  "pm.collectionVariables.set('newStart', newStart.toISOString());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('appointmentId')) { pm.test.skip('sem appointmentId'); return; }",
                  "pm.test('200 ou 409', () => pm.expect(pm.response.code).to.be.oneOf([200, 409, 422]));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"start\": \"{{newStart}}\" }" },
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/reschedule",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentId}}", "reschedule"]
            }

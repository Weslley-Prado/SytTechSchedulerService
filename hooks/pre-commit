#!/usr/bin/env bash
# ============================================================================
# Git pre-commit hook — syttech.portal
# ============================================================================
# Roda automaticamente ANTES de cada "git commit".
# Se qualquer verificação falhar, o commit é BLOQUEADO.
#
# Instalar: ./mvnw initialize  (ou manualmente: cp hooks/pre-commit .git/hooks/)
# Desativar temporariamente: git commit --no-verify
# ============================================================================

set -e

echo "╔══════════════════════════════════════════════════════════╗"
echo "║  🔍 Pre-commit: verificando código...                   ║"
echo "╚══════════════════════════════════════════════════════════╝"
echo ""

# ── 1. Spotless: formatar e verificar ────────────────────────────────────────
echo "✨ [1/3] Spotless — formatando código..."
./mvnw spotless:apply -q
# Re-stage arquivos que o Spotless reformatou
git diff --name-only | xargs -r git add
echo "✅ Spotless OK"
echo ""

# ── 2. Checkstyle: regras de estilo ─────────────────────────────────────────
echo "🔍 [2/3] Checkstyle — verificando estilo..."
./mvnw checkstyle:check -q
echo "✅ Checkstyle OK"
echo ""

# ── 3. PMD: code smells ─────────────────────────────────────────────────────
echo "🐛 [3/3] PMD — detectando code smells..."
./mvnw pmd:check -q
echo "✅ PMD OK"
echo ""

echo "╔══════════════════════════════════════════════════════════╗"
echo "║  ✅ Todas as verificações passaram! Commit permitido.   ║"
echo "╚══════════════════════════════════════════════════════════╝"


    {
      "name": "06 - Holds (release isolada)",
      "item": [
        {
          "name": "POST /appointments/holds — segundo hold (para liberar)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Usa um slot 1h após o anterior para evitar conflito.",
                  "const base = pm.collectionVariables.get('slotStart');",
                  "if (base) {",
                  "    const d = new Date(base);",
                  "    d.setHours(d.getHours() + 24);",
                  "    pm.collectionVariables.set('slotStartAlt', d.toISOString());",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('slotStartAlt')) { pm.test.skip('sem slot'); return; }",
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('holdIdAlt', pm.response.json().holdId);",
                  "}",
                  "pm.test('201 ou 409', () => pm.expect(pm.response.code).to.be.oneOf([201, 409]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitId\": \"{{unitId}}\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"professionalId\": \"{{professionalId}}\",\n  \"start\": \"{{slotStartAlt}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/appointments/holds", "host": ["{{baseUrl}}"], "path": ["appointments", "holds"] }
          }
        },
        {
          "name": "DELETE /appointments/holds/{holdId} — liberar",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/appointments/holds/{{holdIdAlt}}", "host": ["{{baseUrl}}"], "path": ["appointments", "holds", "{{holdIdAlt}}"] }
          },

          "name": "GET /units/{unitId}/services/{serviceId}/professionals",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/units/{{unitId}}/services/{{serviceId}}/professionals",
              "host": ["{{baseUrl}}"],
              "path": ["units", "{{unitId}}", "services", "{{serviceId}}", "professionals"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {

                  "pm.test('200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('code coincide', () => pm.expect(j.code).to.eql(pm.collectionVariables.get('appointmentCode')));"
                ]
              }
            }
